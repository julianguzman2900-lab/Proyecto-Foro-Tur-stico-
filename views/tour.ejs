<%- include('partials/header') %>
<link rel="stylesheet" href="/css/tour.css">

<div class="tour-detail-container">
  <!-- Detalles del Tour (Izquierda) -->
  <div>
    <!-- Galería de Fotos -->
    <div class="tour-gallery">
      <div class="gallery-main">
        <img id="main-gallery-img" src="<%= tour.images[0] || 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=800' %>" 
             alt="<%= tour.title %>"
             onerror="this.onerror=null; this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'800\' height=\'500\' viewBox=\'0 0 800 500\'><rect width=\'100%\' height=\'100%\' fill=\'#e2e8f0\'/><text x=\'50%\' y=\'50%\' font-family=\'Outfit,sans-serif\' font-weight=\'bold\' font-size=\'24\' fill=\'#94a3b8\' text-anchor=\'middle\' dy=\'.3em\'><%= tour.title.replace(/[\']/g, ``) %></text></svg>'">
      </div>
      <div class="gallery-side">
        <% tour.images.forEach((img, index) => { %>
          <img src="<%= img %>" 
               alt="Miniatura <%= index + 1 %>" 
               class="<%= index === 0 ? 'active' : '' %>" 
               onclick="changeImage(this)"
               onerror="this.onerror=null; this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'150\' height=\'100\' viewBox=\'0 0 150 100\'><rect width=\'100%\' height=\'100%\' fill=\'%23cbd5e1\'/></svg>'">
        <% }) %>
      </div>
    </div>

    <!-- Información del Tour -->
    <div class="detail-section">
      <div class="detail-header">
        <h1 class="detail-title"><%= tour.title %></h1>
        <div style="text-align: right;">
          <% if (avgRating) { %>
            <div class="rating-lg">★ <%= avgRating %> / 5.0</div>
            <div class="rating-count"><%= comments.length %> opiniones</div>
          <% } else { %>
            <div class="no-rating">Sin calificaciones aún</div>
          <% } %>
        </div>
      </div>

      <div class="detail-tags">
        <span class="detail-tag"><%= tour.continent %></span>
        <span class="detail-tag"><%= tour.country %></span>
        <span class="detail-tag"><%= tour.city %></span>
        <span class="detail-tag"><%= tour.activity %></span>
      </div>

      <div class="detail-info-grid">
        <div class="info-item">
          <span class="info-label">Dificultad</span>
          <span class="info-val"><%= tour.difficulty %></span>
        </div>
        <div class="info-item">
          <span class="info-label">Duración</span>
          <span class="info-val">Duración: <%= tour.duration %></span>
        </div>
        <div class="info-item">
          <span class="info-label">Cupos Totales</span>
          <span class="info-val"><%= tour.spots_total %></span>
        </div>
        <div class="info-item">
          <span class="info-label">Cupos Libres</span>
          <span class="info-val info-val-success"><%= tour.spots_available %></span>
        </div>
      </div>

      <style>
        .interactive-date-badge {
          padding: 0.5rem 0.75rem;
          border-radius: 8px;
          text-align: center;
          min-width: 90px;
          transition: all 0.2s ease;
        }
        .interactive-date-badge.available {
          cursor: pointer;
          border: 1px solid var(--primary);
          background: #eff6ff;
        }
        .interactive-date-badge.available:hover {
          background: var(--primary-light);
        }
        .interactive-date-badge.sold-out {
          cursor: not-allowed;
          border: 1px solid #e2e8f0;
          background: #f1f5f9;
        }
        .interactive-date-badge.available .date-title {
          color: var(--primary);
        }
        .interactive-date-badge.sold-out .date-title {
          color: #94a3b8;
        }
        .interactive-date-badge.available .date-spots {
          color: #10b981;
        }
        .interactive-date-badge.sold-out .date-spots {
          color: #ef4444;
        }
      </style>

      <!-- Interactive Dates List -->
      <div class="tour-dates-interactive-wrapper" style="margin-top: 1.5rem; background: var(--bg-sec); padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--border);">
        <h4 style="margin-top: 0; margin-bottom: 0.75rem; font-weight: 700; font-family: 'DM Serif Display', serif;">Fechas Disponibles y Cupos</h4>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;" class="interactive-dates-list">
          <% if (tour.dates && tour.dates.length > 0) { %>
            <% 
               const days = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
               const months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
               tour.dates.forEach(d => { 
                 const dateObj = new Date(d.date + 'T00:00:00');
                 const formatted = `${days[dateObj.getDay()]} ${dateObj.getDate()} ${months[dateObj.getMonth()]}`;
                 const isSoldOut = d.status === 'sold_out';
            %>
              <div class="interactive-date-badge <%= isSoldOut ? 'sold-out' : 'available' %>" 
                   data-date="<%= d.date %>"
                   onclick="if(!this.classList.contains('sold-out')) selectBookingDate(this.getAttribute('data-date'))">
                <div class="date-title" style="font-weight: 700; font-size: 0.85rem;"><%= formatted %></div>
                <div class="date-spots" style="font-size: 0.75rem; font-weight: 600; margin-top: 0.2rem;">
                  <%= isSoldOut ? 'Agotado' : `${d.spots_available} cupos` %>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div style="font-size: 0.85rem; color: var(--text-muted);">Sin fechas específicas configuradas.</div>
          <% } %>
        </div>
      </div>

      <script>
        function selectBookingDate(dateStr) {
          const select = document.getElementById('book-date');
          if (select) {
            select.value = dateStr;
            const event = new Event('change');
            select.dispatchEvent(event);
            select.scrollIntoView({ behavior: 'smooth', block: 'center' });
            select.style.borderColor = 'var(--primary)';
            select.style.boxShadow = '0 0 0 3px rgba(37, 99, 235, 0.2)';
            setTimeout(() => {
              select.style.borderColor = '';
              select.style.boxShadow = '';
            }, 1500);
          }
        }
      </script>

      <h3 class="description-title" style="margin-top: 1.5rem;">Descripción</h3>
      <p class="description-text"><%= tour.description %></p>

      <div class="provider-box">
        <div>
          <h4 class="provider-title">Contacto con el Proveedor</h4>
          <p class="provider-info"><%= tour.contact_info %></p>
        </div>
        <span class="provider-badge">Proveedor: <%= tour.seller_name %></span>
      </div>

      <div class="detail-location-box" style="margin-top: 1.5rem; background-color: var(--bg-sec); padding: 1.25rem; border-radius: var(--radius-md); border: 1px solid var(--border);">
        <h4 style="margin-bottom: 0.5rem; font-weight: 700; font-family: 'DM Serif Display', serif;">Ubicación de Inicio</h4>
        <% 
          const isGoogleMapsUrl = /^(https?:\/\/)?(www\.)?(google\.com\/maps|maps\.google\.com|maps\.app\.goo\.gl|goo\.gl\/maps)/i.test(tour.start_address);
          
          let mapsUrl = '';
          let wazeUrl = '';
          
          if (isGoogleMapsUrl) {
            mapsUrl = tour.start_address;
            wazeUrl = `https://waze.com/ul?q=${encodeURIComponent(tour.start_address)}&navigate=yes`;
          } else {
            const mapsQuery = tour.coordinates ? tour.coordinates : encodeURIComponent(tour.start_address + ', ' + tour.city + ', ' + tour.country);
            mapsUrl = `https://www.google.com/maps/search/?api=1&query=${mapsQuery}`;
            const wazeQuery = tour.coordinates ? tour.coordinates : encodeURIComponent(tour.start_address);
            wazeUrl = `https://waze.com/ul?ll=${wazeQuery}&navigate=yes`;
          }
        %>
        <p style="color: var(--text-main); margin-bottom: 1rem;">
          <% if (isGoogleMapsUrl) { %>
            Ubicación compartida mediante enlace de Google Maps
          <% } else { %>
            <%= tour.start_address %>
          <% } %>
        </p>
        <div style="display: flex; gap: 0.75rem;">
          <a href="<%= mapsUrl %>" target="_blank" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.5rem 1rem; display: inline-flex; align-items: center; gap: 0.25rem;">
            Abrir en Google Maps
          </a>
          <a href="<%= wazeUrl %>" target="_blank" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.5rem 1rem; display: inline-flex; align-items: center; gap: 0.25rem;">
            Abrir en Waze
          </a>
        </div>
      </div>
    </div>

    <!-- Recomendaciones -->
    <% if (recommendations.length > 0) { %>
      <div class="recommendations-section">
        <h3 class="section-title">Otros tours recomendados en <%= tour.country %></h3>
        <div class="tours-grid" style="margin-top: 1rem;">
          <% recommendations.forEach(rec => { %>
            <div class="tour-card tour-card-shadow">
              <div class="tour-card-img-container tour-card-img-wrapper">
                <img src="<%= rec.images[0] || 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=600' %>" 
                     alt="<%= rec.title %>" 
                     class="tour-card-img"
                     onerror="this.onerror=null; this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'600\' height=\'400\' viewBox=\'0 0 600 400\'><rect width=\'100%\' height=\'100%\' fill=\'#e2e8f0\'/><text x=\'50%\' y=\'50%\' font-family=\'Outfit,sans-serif\' font-weight=\'bold\' font-size=\'20\' fill=\'#94a3b8\' text-anchor=\'middle\' dy=\'.3em\'><%= rec.title.replace(/[\']/g, ``) %></text></svg>'">
              </div>
              <div class="tour-card-content tour-card-pad">
                <span class="meta-tag meta-tag-inline"><%= rec.city %></span>
                <a href="/tour/<%= rec._id %>" class="tour-card-title rec-tour-title"><%= rec.title %></a>
                <div class="rec-tour-footer">
                  <span class="rec-tour-price">$<%= rec.price %></span>
                  <a href="/tour/<%= rec._id %>" class="btn btn-primary rec-btn">Ver</a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- Comentarios y Calificaciones -->
    <div class="comments-section">
      <h3 class="section-title">Comentarios y Opiniones</h3>
      
      <!-- Formulario para agregar comentarios -->
      <% if (user) { %>
        <form action="/comentario" method="POST" enctype="multipart/form-data" class="comment-form">
          <input type="hidden" name="tour_id" value="<%= tour._id %>">
          
          <h4 class="comment-form-title">Escribe tu opinión</h4>
          
          <div class="form-group" style="margin-bottom: 1rem;">
            <label for="rating">Calificación (1 a 5 estrellas)</label>
            <select id="rating" name="rating" class="form-control" style="width: 150px;" required>
              <option value="5">Excelente (5)</option>
              <option value="4">Muy bueno (4)</option>
              <option value="3">Bueno (3)</option>
              <option value="2">Regular (2)</option>
              <option value="1">Malo (1)</option>
            </select>
          </div>

          <div class="form-group" style="margin-bottom: 1rem;">
            <label for="comment">Tu Comentario</label>
            <textarea id="comment" name="comment" rows="4" class="form-control" placeholder="Comparte tu experiencia con otros viajeros. Recuerda mantener el respeto." required></textarea>
          </div>

          <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="photos">Subir Fotografías (opcional)</label>
            <div class="custom-file-upload">
              <input type="file" id="photos" name="photos" class="form-control file-input-hidden" accept="image/*" multiple onchange="updateFileName(this, 'photos-label')">
              <label for="photos" class="btn btn-secondary btn-block" style="margin:0; text-align:center; font-weight:normal;" id="photos-label">Seleccionar imágenes</label>
            </div>
          </div>

          <button type="submit" class="btn btn-success">Publicar Comentario</button>
        </form>
      <% } else { %>
        <div class="login-prompt-box">
          <p class="login-prompt-text">Debes estar registrado para comentar y calificar.</p>
          <a href="/login" class="btn btn-primary" style="margin-top: 0.75rem;">Iniciar Sesión / Registrarse</a>
        </div>
      <% } %>

      <!-- Listado de comentarios -->
      <div style="margin-top: 2rem;">
        <% if (comments.length === 0) { %>
          <p class="empty-comments">Aún no hay opiniones para esta actividad. ¡Sé el primero en comentar!</p>
        <% } else { %>
          <% comments.forEach(comment => { %>
            <div class="comment-card">
              <div class="comment-header">
                <div>
                  <span class="comment-user"><%= comment.user_name %></span>
                  <span class="comment-date"><%= new Date(comment.created_at).toLocaleDateString('es-ES') %></span>
                </div>
                <div class="comment-rating">
                  <% for(let i=0; i<comment.rating; i++) { %>★<% } %><% for(let i=comment.rating; i<5; i++) { %>☆<% } %>
                </div>
              </div>
              
              <p class="comment-text"><%= comment.comment %></p>

              <% if (comment.photos && comment.photos.length > 0) { %>
                <div class="comment-photos comment-photos-grid">
                  <% comment.photos.forEach(photo => { %>
                    <img src="<%= photo %>" alt="Foto del usuario" class="comment-photo" onclick="openPhotoModal('<%= photo %>')">
                  <% }) %>
                </div>
              <% } %>

              <!-- Acciones de edición/eliminación -->
              <% if (user && (user.role === 'admin' || user.id === comment.user_id)) { %>
                <div class="comment-actions">
                  <button class="btn btn-secondary btn-xs" onclick="openEditCommentModal('<%= comment._id %>', '<%= comment.rating %>', this.dataset.comment)" data-comment="<%= comment.comment %>">Editar</button>
                  <a href="javascript:void(0)" class="btn btn-danger btn-xs" onclick="showCustomConfirm('¿Estás seguro de que deseas eliminar este comentario?', () => window.location.href='/comentario/eliminar/<%= comment._id %>')">Eliminar</a>
                </div>
              <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Panel de Reserva (Derecha) -->
  <div>
    <div class="booking-widget">
      <div class="booking-price">
        $<%= tour.price %> <span>/ persona</span>
      </div>
      
      <div style="margin-bottom: 1.5rem;">
        <span class="booking-status-label">Estado de Cupos</span>
        <div class="booking-status-val <%= tour.spots_available > 0 ? 'status-available' : 'status-empty' %>">
          <%= tour.spots_available > 0 ? `${tour.spots_available} cupos disponibles` : 'Sin cupos disponibles' %>
        </div>
      </div>

      <% if (user) { %>
        <% if (user.role === 'user') { %>
          <% if (tour.spots_available > 0) { %>
            <form action="/reservar" method="POST" onsubmit="return validateBookingSpots(event)">
              <input type="hidden" name="tour_id" value="<%= tour._id %>">
              
              <div class="form-group" style="margin-bottom: 1.25rem;">
                <label for="book-date">Seleccionar Fecha</label>
                <select id="book-date" name="date" class="form-control" required onchange="updateMaxSpots(this)">
                  <option value="" disabled selected>Elige una fecha...</option>
                  <% if (tour.dates && tour.dates.length > 0) { %>
                    <% 
                       const days = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
                       const months = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
                       tour.dates.forEach(d => { 
                         const dateObj = new Date(d.date + 'T00:00:00');
                         const dateStr = `${days[dateObj.getDay()]} ${dateObj.getDate()} de ${months[dateObj.getMonth()]}`;
                    %>
                      <option value="<%= d.date %>" data-spots="<%= d.spots_available %>" <%= d.status === 'sold_out' ? 'disabled' : '' %>>
                        <%= dateStr %> — <%= d.status === 'sold_out' ? 'Agotado' : d.spots_available + ' cupos disponibles' %>
                      </option>
                    <% }) %>
                  <% } else { %>
                    <!-- Fallback para tours antiguos -->
                    <option value="<%= tour.activity_date ? new Date(tour.activity_date).toISOString().split('T')[0] : '' %>" data-spots="<%= tour.spots_available %>">
                      <%= tour.activity_date ? new Date(tour.activity_date).toLocaleDateString('es-ES') : '' %> — <%= tour.spots_available %> cupos disponibles
                    </option>
                  <% } %>
                </select>
              </div>

              <div class="form-group" style="margin-bottom: 1.5rem;">
                <label for="book-spots">Cantidad de Cupos (Máximo 3)</label>
                <input type="number" id="book-spots" name="spots" class="form-control" value="1" min="1" max="3" required>
              </div>

              <button type="submit" class="btn btn-success btn-book">Reservar Actividad</button>
            </form>

            <script>
              function updateMaxSpots(selectElem) {
                const selectedOpt = selectElem.options[selectElem.selectedIndex];
                const available = parseInt(selectedOpt.getAttribute('data-spots')) || 0;
                const spotsInput = document.getElementById('book-spots');
                const newMax = Math.min(3, available);
                spotsInput.max = newMax;
                if (parseInt(spotsInput.value) > newMax) {
                  spotsInput.value = newMax;
                }
              }

              // Llamar al inicio para fijar el máximo de la primera opción
              document.addEventListener('DOMContentLoaded', () => {
                const dateSelect = document.getElementById('book-date');
                if (dateSelect && dateSelect.value) {
                  updateMaxSpots(dateSelect);
                }
              });

              function validateBookingSpots(event) {
                const spotsInput = document.getElementById('book-spots');
                const spotsVal = parseInt(spotsInput.value);
                const maxVal = parseInt(spotsInput.max);
                if (spotsVal > maxVal) {
                  alert('El máximo permitido para esta fecha es de ' + maxVal + ' personas.');
                  event.preventDefault();
                  return false;
                }
                return true;
              }
            </script>
          <% } else { %>
            <button class="btn btn-secondary btn-disabled" disabled>Agotado</button>
          <% } %>
        <% } else { %>
          <div class="admin-book-warning">
            Los proveedores y administradores no pueden realizar reservas de tours.
          </div>
        <% } %>
      <% } else { %>
        <a href="/login" class="btn btn-primary" style="width: 100%;">Inicia sesión para reservar</a>
      <% } %>
    </div>
  </div>
</div>

<!-- Modal para Ampliar Foto de Comentario -->
<div id="photo-modal" class="modal-overlay" style="display: none;" onclick="closePhotoModal()">
  <div class="modal-content modal-content-lg" onclick="event.stopPropagation()">
    <img id="modal-img" src="" alt="Foto ampliada" class="modal-img-full">
    <button class="btn btn-secondary modal-close-btn" onclick="closePhotoModal()">✕</button>
  </div>
</div>

<!-- Modal para Editar Comentario -->
<div id="edit-comment-modal" class="modal-overlay" style="display: none;">
  <div class="modal-content" onclick="event.stopPropagation()">
    <h3 style="margin-bottom: 1.5rem;">Editar Comentario</h3>
    <form id="edit-comment-form" action="" method="POST" enctype="multipart/form-data">
      <div class="form-group" style="margin-bottom: 1rem;">
        <label for="edit-rating">Calificación</label>
        <select id="edit-rating" name="rating" class="form-control" style="width: 150px;" required>
          <option value="5">Excelente (5)</option>
          <option value="4">Muy bueno (4)</option>
          <option value="3">Bueno (3)</option>
          <option value="2">Regular (2)</option>
          <option value="1">Malo (1)</option>
        </select>
      </div>
      <div class="form-group" style="margin-bottom: 1rem;">
        <label for="edit-comment-text">Tu Comentario</label>
        <textarea id="edit-comment-text" name="comment" rows="4" class="form-control" required></textarea>
      </div>
      <div class="form-group" style="margin-bottom: 1.5rem;">
        <label for="edit-photos">Agregar más fotos (opcional)</label>
        <div class="custom-file-upload">
          <input type="file" id="edit-photos" name="photos" class="form-control file-input-hidden" accept="image/*" multiple onchange="updateFileName(this, 'edit-photos-label')">
          <label for="edit-photos" class="btn btn-secondary btn-block" style="margin:0; text-align:center; font-weight:normal;" id="edit-photos-label">Seleccionar imágenes</label>
        </div>
      </div>
      <div style="display: flex; justify-content: flex-end; gap: 1rem;">
        <button type="button" class="btn btn-secondary" onclick="closeEditCommentModal()">Cancelar</button>
        <button type="submit" class="btn btn-success">Guardar Cambios</button>
      </div>
    </form>
  </div>
</div>

<script>
  function updateFileName(input, labelId) {
    const label = document.getElementById(labelId);
    if (input.files && input.files.length > 0) {
      if (input.files.length === 1) {
        label.textContent = input.files[0].name;
      } else {
        label.textContent = input.files.length + ' imágenes seleccionadas';
      }
    } else {
      label.textContent = 'Seleccionar imágenes';
    }
  }

  function changeImage(element) {
    // Cambiar imagen principal
    document.getElementById('main-gallery-img').src = element.src;
    
    // Quitar clase activa de todas las miniaturas
    const thumbnails = document.querySelectorAll('.gallery-side img');
    thumbnails.forEach(thumb => thumb.classList.remove('active'));
    
    // Añadir clase activa a la miniatura seleccionada
    element.classList.add('active');
  }

  function openPhotoModal(imgSrc) {
    document.getElementById('modal-img').src = imgSrc;
    document.getElementById('photo-modal').style.display = 'flex';
  }

  function closePhotoModal() {
    document.getElementById('photo-modal').style.display = 'none';
  }

  function openEditCommentModal(commentId, rating, commentText) {
    const form = document.getElementById('edit-comment-form');
        form.action = '/comentario/editar/' + commentId;

    document.getElementById('edit-rating').value = rating;
    document.getElementById('edit-comment-text').value = commentText;
    
    document.getElementById('edit-comment-modal').style.display = 'flex';
  }

  function closeEditCommentModal() {
    document.getElementById('edit-comment-modal').style.display = 'none';
  }
</script>

<%- include('partials/footer') %>
