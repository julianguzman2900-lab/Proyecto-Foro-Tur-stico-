<%- include('partials/header') %>

<div class="tour-detail-container">
  <!-- Detalles del Tour (Izquierda) -->
  <div>
    <!-- Galería de Fotos -->
    <div class="tour-gallery">
      <div class="gallery-main">
        <img id="main-gallery-img" src="<%= tour.images[0] || 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=800' %>" alt="<%= tour.title %>">
      </div>
      <div class="gallery-side">
        <% tour.images.forEach((img, index) => { %>
          <img src="<%= img %>" alt="Miniatura <%= index + 1 %>" class="<%= index === 0 ? 'active' : '' %>" onclick="changeImage(this)">
        <% }) %>
      </div>
    </div>

    <!-- Información del Tour -->
    <div class="detail-section">
      <div class="detail-header">
        <h1 class="detail-title"><%= tour.title %></h1>
        <div style="text-align: right;">
          <% if (avgRating) { %>
            <div style="font-size: 1.25rem; font-weight: 800; color: var(--warning);">⭐ <%= avgRating %> / 5.0</div>
            <div style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;"><%= comments.length %> opiniones</div>
          <% } else { %>
            <div style="font-size: 0.9rem; color: var(--text-light); font-weight: 600;">Sin calificaciones aún</div>
          <% } %>
        </div>
      </div>

      <div class="detail-tags">
        <span class="detail-tag"><%= tour.continent %></span>
        <span class="detail-tag"><%= tour.country %></span>
        <span class="detail-tag"><%= tour.city %></span>
        <span class="detail-tag"><%= tour.activity %></span>
      </div>

      <div class="detail-info-grid">
        <div class="info-item">
          <span class="info-label">Dificultad</span>
          <span class="info-val"><%= tour.difficulty %></span>
        </div>
        <div class="info-item">
          <span class="info-label">Duración</span>
          <span class="info-val">⌛ <%= tour.duration %></span>
        </div>
        <div class="info-item">
          <span class="info-label">Cupos Totales</span>
          <span class="info-val"><%= tour.spots_total %></span>
        </div>
        <div class="info-item">
          <span class="info-label">Cupos Libres</span>
          <span class="info-val" style="color: var(--success);"><%= tour.spots_available %></span>
        </div>
      </div>

      <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.75rem;">Descripción</h3>
      <p style="color: var(--text-main); white-space: pre-line; margin-bottom: 2rem;"><%= tour.description %></p>

      <div style="background-color: var(--primary-light); padding: 1.25rem; border-radius: var(--radius-md); border: 1px dashed var(--primary); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
        <div>
          <h4 style="color: var(--primary); font-weight: 700;">Contacto con el Proveedor</h4>
          <p style="font-size: 0.9rem; color: var(--text-main); margin-top: 0.25rem;"><%= tour.contact_info %></p>
        </div>
        <span style="font-size: 0.85rem; background-color: var(--bg-main); color: var(--text-muted); font-weight: 700; padding: 0.35rem 0.75rem; border-radius: 50px; border: 1px solid var(--border);">Proveedor: <%= tour.seller_name %></span>
      </div>
    </div>

    <!-- Recomendaciones -->
    <% if (recommendations.length > 0) { %>
      <div class="recommendations-section">
        <h3 class="section-title">Otros tours recomendados en <%= tour.country %></h3>
        <div class="tours-grid" style="margin-top: 1rem;">
          <% recommendations.forEach(rec => { %>
            <div class="tour-card" style="box-shadow: var(--shadow-sm);">
              <div class="tour-card-img-container" style="height: 150px;">
                <img src="<%= rec.images[0] || 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=600' %>" alt="<%= rec.title %>" class="tour-card-img">
              </div>
              <div class="tour-card-content" style="padding: 1rem;">
                <span class="meta-tag" style="margin-bottom: 0.5rem; display: inline-block;"><%= rec.city %></span>
                <a href="/tour/<%= rec._id %>" class="tour-card-title" style="font-size: 1.1rem; line-height: 1.3; margin-bottom: 0.5rem;"><%= rec.title %></a>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 0.5rem; border-top: 1px solid var(--border);">
                  <span style="font-weight: 800; color: var(--primary); font-size: 1.1rem;">$<%= rec.price %></span>
                  <a href="/tour/<%= rec._id %>" class="btn btn-primary" style="padding: 0.35rem 0.75rem; font-size: 0.8rem;">Ver</a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- Comentarios y Calificaciones -->
    <div class="comments-section">
      <h3 class="section-title">Comentarios y Opiniones</h3>
      
      <!-- Formulario para agregar comentarios -->
      <% if (user) { %>
        <form action="/comentario" method="POST" enctype="multipart/form-data" class="comment-form">
          <input type="hidden" name="tour_id" value="<%= tour._id %>">
          
          <h4 style="font-weight: 700; margin-bottom: 1rem;">Escribe tu opinión</h4>
          
          <div class="form-group" style="margin-bottom: 1rem;">
            <label for="rating">Calificación (1 a 5 estrellas)</label>
            <select id="rating" name="rating" class="form-control" style="width: 150px;" required>
              <option value="5">⭐⭐⭐⭐⭐ (5)</option>
              <option value="4">⭐⭐⭐⭐ (4)</option>
              <option value="3">⭐⭐⭐ (3)</option>
              <option value="2">⭐⭐ (2)</option>
              <option value="1">⭐ (1)</option>
            </select>
          </div>

          <div class="form-group" style="margin-bottom: 1rem;">
            <label for="comment">Tu Comentario</label>
            <textarea id="comment" name="comment" rows="4" class="form-control" placeholder="Comparte tu experiencia con otros viajeros. Recuerda mantener el respeto." required></textarea>
          </div>

          <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="photos">Subir Fotografías (opcional)</label>
            <input type="file" id="photos" name="photos" class="form-control" accept="image/*" multiple>
          </div>

          <button type="submit" class="btn btn-success">Publicar Comentario</button>
        </form>
      <% } else { %>
        <div style="background-color: var(--bg-main); border: 1px solid var(--border); padding: 1.5rem; text-align: center; border-radius: var(--radius-md); margin-top: 1.5rem;">
          <p style="font-weight: 600; color: var(--text-muted);">Debes estar registrado para comentar y calificar.</p>
          <a href="/login" class="btn btn-primary" style="margin-top: 0.75rem;">Iniciar Sesión / Registrarse</a>
        </div>
      <% } %>

      <!-- Listado de comentarios -->
      <div style="margin-top: 2rem;">
        <% if (comments.length === 0) { %>
          <p style="color: var(--text-light); text-align: center; font-style: italic; padding: 2rem 0;">Aún no hay opiniones para esta actividad. ¡Sé el primero en comentar!</p>
        <% } else { %>
          <% comments.forEach(comment => { %>
            <div class="comment-card">
              <div class="comment-header">
                <div>
                  <span class="comment-user"><%= comment.user_name %></span>
                  <span style="font-size: 0.8rem; color: var(--text-light); margin-left: 0.5rem;"><%= new Date(comment.created_at).toLocaleDateString('es-ES') %></span>
                </div>
                <div class="comment-rating">
                  <% for(let i=0; i<comment.rating; i++) { %>★<% } %><% for(let i=comment.rating; i<5; i++) { %>☆<% } %>
                </div>
              </div>
              
              <p class="comment-text"><%= comment.comment %></p>

              <% if (comment.photos && comment.photos.length > 0) { %>
                <div class="comment-photos" style="margin-bottom: 1rem;">
                  <% comment.photos.forEach(photo => { %>
                    <img src="<%= photo %>" alt="Foto del usuario" class="comment-photo" onclick="openPhotoModal('<%= photo %>')">
                  <% }) %>
                </div>
              <% } %>

              <!-- Acciones de edición/eliminación -->
              <% if (user && (user.role === 'admin' || user.id === comment.user_id)) { %>
                <div style="display: flex; gap: 0.75rem; justify-content: flex-end;">
                  <button class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;" onclick="openEditCommentModal('<%= comment._id %>', '<%= comment.rating %>', '<%= comment.comment.replace(/'/g, '\\&apos;') %>')">Editar</button>
                  <a href="/comentario/eliminar/<%= comment._id %>" class="btn btn-danger" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;" onclick="return confirm('¿Estás seguro de que deseas eliminar este comentario?')">Eliminar</a>
                </div>
              <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Panel de Reserva (Derecha) -->
  <div>
    <div class="booking-widget">
      <div class="booking-price">
        $<%= tour.price %> <span>/ persona</span>
      </div>
      
      <div style="margin-bottom: 1.5rem;">
        <span style="font-weight: 700; color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">Estado de Cupos</span>
        <div style="font-size: 1.25rem; font-weight: 800; color: <%= tour.spots_available > 0 ? 'var(--success)' : 'var(--danger)' %>; margin-top: 0.25rem;">
          <%= tour.spots_available > 0 ? `${tour.spots_available} cupos disponibles` : 'Sin cupos disponibles' %>
        </div>
      </div>

      <% if (user) { %>
        <% if (user.role === 'user') { %>
          <% if (tour.spots_available > 0) { %>
            <form action="/reservar" method="POST">
              <input type="hidden" name="tour_id" value="<%= tour._id %>">
              
              <div class="form-group" style="margin-bottom: 1.25rem;">
                <label for="book-date">Seleccionar Fecha</label>
                <input type="date" id="book-date" name="date" class="form-control" required min="<%= new Date().toISOString().split('T')[0] %>">
              </div>

              <div class="form-group" style="margin-bottom: 1.5rem;">
                <label for="book-spots">Cantidad de Cupos</label>
                <input type="number" id="book-spots" name="spots" class="form-control" value="1" min="1" max="<%= tour.spots_available %>" required>
              </div>

              <button type="submit" class="btn btn-success" style="width: 100%; font-size: 1.05rem; padding: 0.9rem;">Reservar Actividad</button>
            </form>
          <% } else { %>
            <button class="btn btn-secondary" style="width: 100%; cursor: not-allowed;" disabled>Agotado</button>
          <% } %>
        <% } else { %>
          <div style="background-color: var(--bg-sec); padding: 1rem; border-radius: var(--radius-sm); font-size: 0.9rem; color: var(--text-muted); font-weight: 600; text-align: center;">
            Los proveedores y administradores no pueden realizar reservas de tours.
          </div>
        <% } %>
      <% } else { %>
        <a href="/login" class="btn btn-primary" style="width: 100%;">Inicia sesión para reservar</a>
      <% } %>
    </div>
  </div>
</div>

<!-- Modal para Ampliar Foto de Comentario -->
<div id="photo-modal" class="modal-overlay" style="display: none;" onclick="closePhotoModal()">
  <div class="modal-content" style="max-width: 600px; padding: 1.5rem; position: relative;" onclick="event.stopPropagation()">
    <img id="modal-img" src="" alt="Foto ampliada" style="width: 100%; height: auto; border-radius: var(--radius-sm); max-height: 80vh; object-fit: contain;">
    <button class="btn btn-secondary" style="position: absolute; top: 1rem; right: 1rem; padding: 0.25rem 0.5rem;" onclick="closePhotoModal()">✕</button>
  </div>
</div>

<!-- Modal para Editar Comentario -->
<div id="edit-comment-modal" class="modal-overlay" style="display: none;">
  <div class="modal-content" onclick="event.stopPropagation()">
    <h3 style="margin-bottom: 1.5rem;">Editar Comentario</h3>
    <form id="edit-comment-form" action="" method="POST" enctype="multipart/form-data">
      <div class="form-group" style="margin-bottom: 1rem;">
        <label for="edit-rating">Calificación</label>
        <select id="edit-rating" name="rating" class="form-control" style="width: 150px;" required>
          <option value="5">⭐⭐⭐⭐⭐ (5)</option>
          <option value="4">⭐⭐⭐⭐ (4)</option>
          <option value="3">⭐⭐⭐ (3)</option>
          <option value="2">⭐⭐ (2)</option>
          <option value="1">⭐ (1)</option>
        </select>
      </div>
      <div class="form-group" style="margin-bottom: 1rem;">
        <label for="edit-comment-text">Tu Comentario</label>
        <textarea id="edit-comment-text" name="comment" rows="4" class="form-control" required></textarea>
      </div>
      <div class="form-group" style="margin-bottom: 1.5rem;">
        <label for="edit-photos">Agregar más fotos (opcional)</label>
        <input type="file" id="edit-photos" name="photos" class="form-control" accept="image/*" multiple>
      </div>
      <div style="display: flex; justify-content: flex-end; gap: 1rem;">
        <button type="button" class="btn btn-secondary" onclick="closeEditCommentModal()">Cancelar</button>
        <button type="submit" class="btn btn-success">Guardar Cambios</button>
      </div>
    </form>
  </div>
</div>

<script>
  function changeImage(element) {
    // Cambiar imagen principal
    document.getElementById('main-gallery-img').src = element.src;
    
    // Quitar clase activa de todas las miniaturas
    const thumbnails = document.querySelectorAll('.gallery-side img');
    thumbnails.forEach(thumb => thumb.classList.remove('active'));
    
    // Añadir clase activa a la miniatura seleccionada
    element.classList.add('active');
  }

  function openPhotoModal(imgSrc) {
    document.getElementById('modal-img').src = imgSrc;
    document.getElementById('photo-modal').style.display = 'flex';
  }

  function closePhotoModal() {
    document.getElementById('photo-modal').style.display = 'none';
  }

  function openEditCommentModal(commentId, rating, commentText) {
    const form = document.getElementById('edit-comment-form');
        form.action = '/comentario/editar/' + commentId;

    document.getElementById('edit-rating').value = rating;
    document.getElementById('edit-comment-text').value = commentText;
    
    document.getElementById('edit-comment-modal').style.display = 'flex';
  }

  function closeEditCommentModal() {
    document.getElementById('edit-comment-modal').style.display = 'none';
  }
</script>

<%- include('partials/footer') %>
