<%- include('partials/header') %>
<link rel="stylesheet" href="/css/my-bookings.css">

<h2 class="section-title">Mi Historial de Reservas</h2>

<div class="calendar-view">
  <p class="bookings-info-text">
    Aquí se listan tus próximas actividades agendadas. Utiliza los botones "Ir con..." para iniciar la navegación a la ubicación del tour.
  </p>

  <% if (bookings.length === 0) { %>
    <div class="empty-bookings-box">
      <p class="empty-bookings-text">No tienes reservas confirmadas en este momento.</p>
      <a href="/" class="btn btn-primary" style="margin-top: 1rem;">Explorar Actividades</a>
    </div>
  <% } else { %>
    <div class="bookings-list">
      <% bookings.forEach(booking => { %>
        <div class="booking-item-card">
          <div class="booking-item-info">
            <h4><%= booking.tour_title %></h4>
            <p class="booking-item-detail"><strong>Fecha agendada:</strong> <%= new Date(booking.date).toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
            <p><strong>Cupos reservados:</strong> <%= booking.spots %> <%= booking.spots === 1 ? 'persona' : 'personas' %></p>
            <p><strong>Dirección de destino:</strong> <%= booking.location %></p>
            <p class="booking-item-total">Total pagado: $<%= booking.price * booking.spots %></p>
          </div>
          
          <div class="booking-item-actions">
            <% if (booking.tourExists) { %>
              <a href="/tour/<%= booking.tour_id %>" class="btn btn-secondary btn-booking">Ver Actividad</a>
              <a href="<%= booking.googleMapsUrl %>" target="_blank" class="btn btn-primary btn-booking btn-gmaps">Ir con Google Maps</a>
              <a href="<%= booking.wazeUrl %>" target="_blank" class="btn btn-success btn-booking btn-waze">Ir con Waze</a>
              
              <form action="/reservar/cancelar/<%= booking.id %>" method="POST" style="margin-top: 0.5rem;" onsubmit="return confirm('¿Estás seguro de que deseas cancelar esta reserva? Esta acción no se puede deshacer.');">
                <button type="submit" class="btn btn-danger btn-booking">Cancelar Reserva</button>
              </form>
            <% } else { %>
              <span class="booking-cancelled-text">Actividad cancelada / no disponible</span>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
