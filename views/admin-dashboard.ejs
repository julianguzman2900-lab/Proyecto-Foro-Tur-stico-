<%- include('partials/header') %>
<link rel="stylesheet" href="/css/admin-dashboard.css">

<div class="dashboard-grid">
  <!-- Sidebar -->
  <aside class="dashboard-sidebar">
    <div class="sidebar-profile">
      <h3><%= user.name %></h3>
      <p class="role-label">ADMINISTRADOR</p>
    </div>
    
    <ul class="dashboard-menu">
      <li><a href="/admin/dashboard" class="dashboard-menu-link active">Auditorías e Informes</a></li>
      <li><a href="/quejas" class="dashboard-menu-link">Quejas y Sugerencias</a></li>
    </ul>
  </aside>

  <!-- Contenido -->
  <div class="dashboard-content">
    
    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-num"><%= stats.sellersTotal %></div>
        <div class="stat-label">Proveedores Registrados</div>
      </div>
      <div class="stat-card">
        <div class="stat-num warning"><%= stats.sellersPending %></div>
        <div class="stat-label">Proveedores Pendientes</div>
      </div>
      <div class="stat-card">
        <div class="stat-num primary"><%= stats.toursTotal %></div>
        <div class="stat-label">Publicaciones en MongoDB</div>
      </div>
      <div class="stat-card">
        <div class="stat-num warning"><%= stats.toursPending %></div>
        <div class="stat-label">Tours por Auditar</div>
      </div>
    </div>

    <!-- Tabla 1: Auditoría de Vendedores (MySQL) -->
    <section class="table-container">
      <div class="table-header">
        <h3>Auditoría de Cuentas de Vendedores</h3>
      </div>
      <table>
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Email</th>
            <th>Fecha de Registro</th>
            <th>Estado Actual</th>
            <th>Acción de Auditoría</th>
          </tr>
        </thead>
        <tbody>
          <% if (sellers.length === 0) { %>
            <tr>
              <td colspan="5" class="empty-table-state">No hay vendedores registrados.</td>
            </tr>
          <% } else { %>
            <% sellers.forEach(seller => { %>
              <tr>
                <td><strong><%= seller.name %></strong></td>
                <td><%= seller.email %></td>
                <td><%= new Date(seller.created_at).toLocaleDateString('es-ES') %></td>
                <td>
                  <% if (seller.status === 'approved') { %>
                    <span class="badge badge-approved">Aprobado</span>
                  <% } else if (seller.status === 'pending') { %>
                    <span class="badge badge-pending">Pendiente</span>
                  <% } else { %>
                    <span class="badge badge-rejected" title="<%= seller.rejection_reason %>">Rechazado</span>
                  <% } %>
                </td>
                <td>
                  <div class="action-buttons">
                    <% if (seller.status === 'pending') { %>
                      <form action="/admin/vendedor/auditar" method="POST" style="display: inline;">
                        <input type="hidden" name="seller_id" value="<%= seller.id %>">
                        <input type="hidden" name="action" value="approve">
                        <button type="submit" class="btn btn-success btn-sm">Aprobar</button>
                      </form>
                      <button class="btn btn-danger btn-sm" onclick="openRejectSellerModal('<%= seller.id %>')">Rechazar</button>
                    <% } else if (seller.status === 'approved') { %>
                      <span style="font-size: 0.85rem; color: var(--success); font-weight: bold;">Cuenta aprobada</span>
                    <% } else if (seller.status === 'rejected') { %>
                      <span style="font-size: 0.85rem; color: var(--danger); font-weight: bold;">Cuenta rechazada</span>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </section>

    <!-- Tabla 2: Auditoría de Publicaciones (MongoDB) -->
    <section class="table-container">
      <div class="table-header">
        <h3>Auditoría de Publicaciones del Foro</h3>
      </div>
      <table>
        <thead>
          <tr>
            <th>Imagen</th>
            <th>Título del Tour</th>
            <th>Proveedor</th>
            <th>Estado</th>
            <th>Auditar / Administrar</th>
          </tr>
        </thead>
        <tbody>
          <% if (tours.length === 0) { %>
            <tr>
              <td colspan="5" class="empty-table-state">No hay publicaciones en el foro.</td>
            </tr>
          <% } else { %>
            <% tours.forEach(tour => { %>
              <tr>
                <td>
                  <img src="<%= tour.images[0] || 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=150' %>" alt="" class="tour-thumbnail">
                </td>
                <td>
                  <a href="/tour/<%= tour._id %>" class="tour-title-link"><%= tour.title %></a>
                  <div class="tour-location-sub"><%= tour.city %>, <%= tour.country %></div>
                </td>
                <td><%= tour.seller_name %></td>
                <td>
                  <% if (tour.status === 'approved') { %>
                    <span class="badge badge-approved">Aprobado</span>
                  <% } else if (tour.status === 'pending') { %>
                    <span class="badge badge-pending">Pendiente</span>
                  <% } else { %>
                    <span class="badge badge-rejected" title="<%= tour.rejection_reason %>">Rechazado</span>
                  <% } %>
                </td>
                <td>
                  <div class="action-buttons">
                    <% if (tour.status === 'pending') { %>
                      <form action="/admin/tour/auditar" method="POST" style="display: inline;">
                        <input type="hidden" name="tour_id" value="<%= tour._id %>">
                        <input type="hidden" name="action" value="approve">
                        <button type="submit" class="btn btn-success btn-sm">Aprobar</button>
                      </form>
                      <button class="btn btn-danger btn-sm" onclick="openRejectTourModal('<%= tour._id %>')">Rechazar</button>
                    <% } else if (tour.status === 'approved') { %>
                      <span style="font-size: 0.85rem; color: var(--success); font-weight: bold;">Publicación aprobada</span>
                    <% } else if (tour.status === 'rejected') { %>
                      <span style="font-size: 0.85rem; color: var(--danger); font-weight: bold;">Publicación rechazada</span>
                    <% } %>
                    <a href="javascript:void(0)" class="btn btn-danger btn-sm btn-muted" onclick="showCustomConfirm('¿Estás seguro de que deseas ELIMINAR esta publicación del foro permanentemente?', () => window.location.href='/tour/eliminar/<%= tour._id %>')">Eliminar</a>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </section>
  </div>
</div>

<!-- Modal para Rechazar Vendedor -->
<div id="reject-seller-modal" class="modal-overlay" style="display: none;">
  <div class="modal-content" onclick="event.stopPropagation()">
    <h3 class="modal-header-margin">Rechazar Vendedor</h3>
    <form action="/admin/vendedor/auditar" method="POST">
      <input type="hidden" id="reject-seller-id" name="seller_id" value="">
      <input type="hidden" name="action" value="reject">
      
      <div class="form-group form-group-margin">
        <label for="reject-seller-reason">Motivo de Rechazo (Campo obligatorio)</label>
        <textarea id="reject-seller-reason" name="rejection_reason" rows="4" class="form-control" placeholder="Escribe el motivo del porqué del rechazo de esta cuenta..." required></textarea>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeRejectSellerModal()">Cancelar</button>
        <button type="submit" class="btn btn-danger">Rechazar Cuenta</button>
      </div>
    </form>
  </div>
</div>

<!-- Modal para Rechazar Publicación de Tour -->
<div id="reject-tour-modal" class="modal-overlay" style="display: none;">
  <div class="modal-content" onclick="event.stopPropagation()">
    <h3 class="modal-header-margin">Rechazar Publicación de Tour</h3>
    <form action="/admin/tour/auditar" method="POST">
      <input type="hidden" id="reject-tour-id" name="tour_id" value="">
      <input type="hidden" name="action" value="reject">
      
      <div class="form-group form-group-margin">
        <label for="reject-tour-reason">Motivo de Rechazo (Campo obligatorio)</label>
        <textarea id="reject-tour-reason" name="rejection_reason" rows="4" class="form-control" placeholder="Escribe el porqué del rechazo de esta publicación..." required></textarea>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeRejectTourModal()">Cancelar</button>
        <button type="submit" class="btn btn-danger">Rechazar Publicación</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openRejectSellerModal(sellerId) {
    document.getElementById('reject-seller-id').value = sellerId;
    document.getElementById('reject-seller-modal').style.display = 'flex';
  }

  function closeRejectSellerModal() {
    document.getElementById('reject-seller-modal').style.display = 'none';
  }

  function openRejectTourModal(tourId) {
    document.getElementById('reject-tour-id').value = tourId;
    document.getElementById('reject-tour-modal').style.display = 'flex';
  }

  function closeRejectTourModal() {
    document.getElementById('reject-tour-modal').style.display = 'none';
  }
</script>

<%- include('partials/footer') %>
