<%- include('partials/header') %>
<link rel="stylesheet" href="/css/complaints.css">

<h2 class="section-title">Buzón de Quejas y Sugerencias</h2>

<div class="complaints-grid">
  <!-- Formulario de Envío (Solo para viajeros) -->
  <div>
    <% if (user.role === 'user') { %>
      <div class="detail-section">
        <h3 style="font-weight: 800; margin-bottom: 1rem;">Enviar Nueva Sugerencia / Queja</h3>
        <p class="complaints-info-text">
          Tus sugerencias nos ayudan a mejorar la plataforma. Los proveedores y administradores podrán leer tu mensaje y responderte directamente aquí.
        </p>
        
        <form action="/quejas" method="POST">
          <div class="form-group" style="margin-bottom: 1.25rem;">
            <label for="subject">Asunto</label>
            <input type="text" id="subject" name="subject" class="form-control" placeholder="Ej: Problema con la reserva de snorkel / Sugerencia de filtro" required>
          </div>

          <div class="form-group" style="margin-bottom: 1.25rem;">
            <label for="tour_id">Seleccionar Actividad / Tour relacionado (opcional)</label>
            <select id="tour_id" name="tour_id" class="form-control">
              <option value="">-- General / Ninguno --</option>
              <% tours.forEach(t => { %>
                <option value="<%= t._id %>"><%= t.title %> (Proveedor: <%= t.seller_name %>)</option>
              <% }) %>
            </select>
          </div>
          
          <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="message">Mensaje Detallado</label>
            <textarea id="message" name="message" rows="6" class="form-control" placeholder="Describe claramente tu sugerencia o reclamo..." required></textarea>
          </div>
          
          <button type="submit" class="btn btn-primary" style="width: 100%;">Enviar Mensaje</button>
        </form>
      </div>
    <% } else { %>
      <div class="admin-mode-box">
        <h3 class="admin-mode-title">Modo de Gestión de Quejas</h3>
        <p class="admin-mode-desc">
          Como <%= user.role === 'admin' ? 'Administrador' : 'Proveedor' %>, puedes ver todos los mensajes enviados por los viajeros y responderlos directamente para resolver sus dudas o comentarios.
        </p>
      </div>
    <% } %>
  </div>

  <!-- Listado de Mensajes -->
  <div class="messages-list">
    <h3 style="font-weight: 800; margin-bottom: 1.25rem;">Historial de Mensajes</h3>
    
    <% if (complaints.length === 0) { %>
      <p class="empty-messages">No hay quejas ni sugerencias registradas.</p>
    <% } else { %>
      <% complaints.forEach(complaint => { %>
        <div class="comment-card <%= complaint.status === 'pending' ? 'card-pending' : 'card-approved' %>">
          <div class="message-header">
            <span class="message-subject"><%= complaint.subject %></span>
            <span class="badge <%= complaint.status === 'pending' ? 'badge-pending' : 'badge-approved' %> badge-sm">
              <%= complaint.status === 'pending' ? 'Pendiente' : 'Respondido' %>
            </span>
          </div>
          
          <p class="message-meta">
            Enviado por: <%= complaint.user_name %> (<%= complaint.user_email %>) el <%= new Date(complaint.created_at).toLocaleDateString('es-ES') %>
          </p>

          <% if (complaint.tour_title) { %>
            <div style="font-size: 0.8rem; background: #eff6ff; padding: 0.4rem 0.6rem; border-radius: 6px; color: var(--primary); display: inline-block; margin-bottom: 0.75rem; font-weight: 600;">
              Actividad Relacionada: <%= complaint.tour_title %>
            </div>
          <% } %>
          
          <p class="message-body"><%= complaint.message %></p>

          <!-- Respuesta -->
          <% if (complaint.reply) { %>
            <div class="reply-box">
              <span class="reply-header">Respuesta de <%= complaint.replied_by %>:</span>
              <p class="reply-body"><%= complaint.reply %></p>
            </div>
          <% } else if (user.role === 'admin' || user.role === 'seller') { %>
            <!-- Formulario de Respuesta para Admin o Vendedor -->
            <form action="/quejas/responder/<%= complaint.id %>" method="POST" class="reply-form">
              <div class="form-group" style="margin-bottom: 0.75rem;">
                <label for="reply-<%= complaint.id %>" class="reply-label">Responder Mensaje</label>
                <textarea id="reply-<%= complaint.id %>" name="reply" rows="3" class="form-control" placeholder="Escribe tu respuesta oficial aquí..." required></textarea>
              </div>
              <button type="submit" class="btn btn-success btn-reply">Enviar Respuesta</button>
            </form>
          <% } %>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
