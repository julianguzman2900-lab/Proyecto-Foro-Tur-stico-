<%- include('partials/header') %>
<link rel="stylesheet" href="/css/seller-dashboard.css">

<div class="dashboard-grid">
  <!-- Sidebar Menú -->
  <aside class="dashboard-sidebar">
    <div class="sidebar-profile">
      <h3><%= user.name %></h3>
      <p class="role-label">Proveedor verificado</p>
      <% if (user.company_name) { %>
        <p class="company-label" style="font-size: 0.85rem; margin-top: 0.25rem; font-weight: bold; color: var(--text-muted);"><%= user.company_name %></p>
      <% } %>
      <% if (user.country) { %>
        <p class="country-label" style="font-size: 0.8rem; color: var(--text-light);"><%= user.country %></p>
      <% } %>
      
      <% if (user.status === 'pending') { %>
        <span class="badge badge-pending badge-inline">Cuenta en revisión</span>
      <% } else if (user.status === 'approved') { %>
        <span class="badge badge-approved badge-inline">Cuenta Aprobada</span>
      <% } else { %>
        <span class="badge badge-rejected badge-inline">Cuenta Rechazada</span>
      <% } %>
    </div>
    
    <ul class="dashboard-menu">
      <li><a href="/vendedor/dashboard" class="dashboard-menu-link active">Mis Publicaciones</a></li>
      <li><a href="/quejas" class="dashboard-menu-link">Sugerencias & Quejas</a></li>
    </ul>
  </aside>

  <!-- Contenido Principal -->
  <div class="dashboard-content">
    
    <% if (user.status !== 'approved') { %>
      <div class="alert alert-warning alert-no-margin">
        <strong>Cuenta inactiva:</strong> Tu cuenta de proveedor está en espera de aprobación por parte de la administración de la plataforma. Podrás publicar nuevos tours una vez que seas aprobado.
      </div>
    <% } %>

    <!-- Tarjeta de Estadísticas Rápidas -->
    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-num"><%= stats.total %></div>
        <div class="stat-label">Publicaciones Totales</div>
      </div>
      <div class="stat-card">
        <div class="stat-num success"><%= stats.active %></div>
        <div class="stat-label">Tours Activos</div>
      </div>
      <div class="stat-card">
        <div class="stat-num warning"><%= stats.pending %></div>
        <div class="stat-label">En Revisión</div>
      </div>
    </div>

    <!-- Sección de Publicar Nuevo Tour -->
    <% if (user.status === 'approved') { %>
      <section class="detail-section section-no-margin">
        <h3 class="section-title">Publicar Nueva Actividad Turística</h3>
        
        <form action="/tour" method="POST" enctype="multipart/form-data" onsubmit="return validateTourForm(this)">
          <div class="grid-2-col">
            <div class="form-group">
              <label for="title">Título del Tour</label>
              <input type="text" id="title" name="title" class="form-control" placeholder="Ej: Tour de snorkel en Arrecife de Coral" required>
            </div>
            
            <div class="form-group">
              <label for="activity">Tipo de Actividad</label>
              <input type="text" id="activity" name="activity" class="form-control" placeholder="Ej: Snorkel / Senderismo / Cultural" required>
            </div>
          </div>

          <div class="form-group form-group-margin">
            <label for="description">Descripción Detallada (Solo letras, números y signos comunes)</label>
            <textarea id="description" name="description" rows="5" class="form-control" placeholder="Describe los itinerarios, qué incluye la actividad, políticas de seguridad, etc." required></textarea>
          </div>

          <div class="grid-4-col">
            <div class="form-group">
              <label for="continent">Continente</label>
              <select id="continent" name="continent" class="form-control" required>
                <option value="">Selecciona</option>
                <option value="América">América</option>
                <option value="Europa">Europa</option>
                <option value="Asia">Asia</option>
                <option value="África">África</option>
                <option value="Oceanía">Oceanía</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="country">País</label>
              <input type="text" id="country" name="country" class="form-control" placeholder="Ej: Costa Rica" required>
            </div>
            
            <div class="form-group">
              <label for="city">Ciudad</label>
              <input type="text" id="city" name="city" class="form-control" placeholder="Ej: Limón" required>
            </div>

            <div class="form-group">
              <label for="difficulty">Dificultad</label>
              <select id="difficulty" name="difficulty" class="form-control" required>
                <option value="Fácil">Fácil</option>
                <option value="Medio">Medio</option>
                <option value="Difícil">Difícil</option>
              </select>
            </div>
          </div>

          <div class="grid-4-col">
            <div class="form-group">
              <label for="duration">Duración</label>
              <input type="text" id="duration" name="duration" class="form-control" placeholder="Ej: 3 horas o 2 días" required>
            </div>

            <div class="form-group">
              <label for="price">Precio por Persona ($)</label>
              <input type="number" id="price" name="price" class="form-control" min="1" step="0.01" placeholder="Ej: 45" required>
            </div>

            <div class="form-group">
              <label for="spots_total">Cupos Totales</label>
              <input type="number" id="spots_total" name="spots_total" class="form-control" min="1" placeholder="Ej: 20" required>
            </div>

            <div class="form-group">
              <label for="images">Fotos de la Actividad</label>
              <input type="file" id="images" name="images" class="form-control" accept="image/*" multiple required>
            </div>
          </div>

          <div class="form-group form-group-margin">
            <label for="contact_info">Información de Contacto directa (Teléfono, Whatsapp, etc.)</label>
            <input type="text" id="contact_info" name="contact_info" class="form-control" placeholder="Ej: WhatsApp +506 8888-8888 o reservas@ejemplo.com" required>
          </div>

          <div class="grid-2-col" style="margin-top: 1rem; margin-bottom: 1.25rem;">
            <div class="form-group">
              <label for="start_address">Dirección de inicio del tour</label>
              <input type="text" id="start_address" name="start_address" class="form-control" placeholder="Ej: 100m norte de la Iglesia de La Fortuna" required>
            </div>
            <div class="form-group">
              <label for="coordinates">Coordenadas (Latitud, Longitud) - Opcional</label>
              <input type="text" id="coordinates" name="coordinates" class="form-control" placeholder="Ej: 10.4687,-84.6433">
            </div>
          </div>

          <div class="form-group form-group-margin">
            <label for="activity_date">Fecha de la Actividad</label>
            <input type="date" id="activity_date" name="activity_date" class="form-control" required min="<%= new Date().toISOString().split('T')[0] %>">
          </div>

          <button type="submit" class="btn btn-success btn-block">Crear y Enviar Publicación</button>
        </form>
      </section>
    <% } %>

    <!-- Listado de Publicaciones Existentes -->
    <section class="table-container">
      <div class="table-header">
        <h3>Estado de tus Publicaciones</h3>
      </div>
      
      <table>
        <thead>
          <tr>
            <th>Imagen</th>
            <th>Título del Tour</th>
            <th>Ubicación</th>
            <th>Precio</th>
            <th>Cupos</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (tours.length === 0) { %>
            <tr>
              <td colspan="7" class="empty-table-state">No has subido ninguna publicación todavía.</td>
            </tr>
          <% } else { %>
            <% tours.forEach(tour => { %>
              <tr>
                <td>
                  <img src="<%= tour.images[0] || 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=150' %>" alt="" class="tour-thumbnail-lg">
                </td>
                <td>
                  <div style="font-weight: 700;"><%= tour.title %></div>
                  <div class="tour-location-sub"><%= tour.activity %></div>
                </td>
                <td><%= tour.city %>, <%= tour.country %></td>
                <td><strong>$<%= tour.price %></strong></td>
                <td><%= tour.spots_available %>/<%= tour.spots_total %></td>
                <td>
                  <% 
                    const isExpired = tour.status === 'approved' && new Date(tour.activity_date) < new Date();
                  %>
                  <% if (tour.status === 'approved' && !isExpired) { %>
                    <span class="badge badge-approved">Activa</span>
                  <% } else if (tour.status === 'finished') { %>
                    <span class="badge badge-secondary" style="background-color: var(--text-muted); color: #fff;">Finalizada</span>
                  <% } else if (isExpired) { %>
                    <span class="badge badge-rejected" style="background-color: var(--warning); color: #fff;">Caducada</span>
                  <% } else if (tour.status === 'pending') { %>
                    <span class="badge badge-pending">En revisión</span>
                  <% } else { %>
                    <span class="badge badge-rejected" style="cursor: help;" title="Haz clic para ver el motivo">Rechazada</span>
                  <% } %>
                </td>
                <td>
                  <div class="action-buttons">
                    <% if (tour.status === 'pending' || tour.status === 'rejected') { %>
                      <button class="btn btn-secondary btn-sm" onclick="openEditTourModal(this.dataset.tour)" data-tour="<%= JSON.stringify(tour) %>">Editar</button>
                    <% } %>
                    <% if (tour.status === 'approved' && !isExpired) { %>
                      <form action="/tour/finalizar/<%= tour._id %>" method="POST" style="display:inline;" onsubmit="return confirm('¿Estás seguro de marcar esta actividad como finalizada? Esto impedirá nuevas reservas.')">
                        <button type="submit" class="btn btn-warning btn-sm" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; font-weight: 600;">Finalizar</button>
                      </form>
                    <% } %>
                    <a href="/tour/eliminar/<%= tour._id %>" class="btn btn-danger btn-sm" onclick="return confirm('¿Estás seguro de que deseas eliminar este tour?')">Eliminar</a>
                  </div>
                </td>
              </tr>
              <% if (tour.status === 'rejected' && tour.rejection_reason) { %>
                <tr class="reject-row">
                  <td colspan="7" class="reject-cell">
                    <strong>Motivo de rechazo de la administración:</strong> <%= tour.rejection_reason %>
                  </td>
                </tr>
              <% } %>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </section>

    <!-- Sección de Rendimiento Financiero -->
    <section class="table-container" style="margin-top: 2rem; padding: 1.5rem;">
      <h3 style="margin-bottom: 1.5rem; font-family: 'DM Serif Display', serif;">Rendimiento Financiero</h3>
      
      <div class="stat-grid" style="margin-bottom: 2rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
        <div class="stat-card" style="background: var(--primary-light); border: 1px solid rgba(37,99,235,0.1); padding: 1.25rem; border-radius: var(--radius-md); text-align: center;">
          <div class="stat-num" style="font-size: 2rem; font-weight: 800; color: var(--primary);">$<%= financials.totalRevenue.toFixed(2) %></div>
          <div class="stat-label" style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600; margin-top: 0.25rem;">Ingresos Generados</div>
        </div>
        <div class="stat-card" style="background: var(--success-light); border: 1px solid rgba(16,185,129,0.1); padding: 1.25rem; border-radius: var(--radius-md); text-align: center;">
          <div class="stat-num" style="font-size: 2rem; font-weight: 800; color: var(--success);"><%= financials.totalTickets %></div>
          <div class="stat-label" style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600; margin-top: 0.25rem;">Boletos Vendidos</div>
        </div>
        <div class="stat-card" style="background: #F3F4F6; border: 1px solid var(--border); padding: 1.25rem; border-radius: var(--radius-md); text-align: center;">
          <div class="stat-num" style="font-size: 2rem; font-weight: 800; color: var(--text-main);"><%= financials.totalSales %></div>
          <div class="stat-label" style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600; margin-top: 0.25rem;">Reservas Totales</div>
        </div>
      </div>

      <h4 style="margin-bottom: 1rem; font-weight: 700; color: var(--text-main);">Historial de Compras de Clientes</h4>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; min-width: 600px;">
          <thead>
            <tr style="border-bottom: 2px solid var(--border); text-align: left; font-size: 0.9rem; color: var(--text-muted);">
              <th style="padding: 0.75rem 1rem;">Cliente</th>
              <th style="padding: 0.75rem 1rem;">Actividad</th>
              <th style="padding: 0.75rem 1rem;">Fecha Reservada</th>
              <th style="padding: 0.75rem 1rem; text-align: center;">Cantidad</th>
              <th style="padding: 0.75rem 1rem; text-align: right;">Importe</th>
            </tr>
          </thead>
          <tbody>
            <% if (financials.history.length === 0) { %>
              <tr>
                <td colspan="5" style="text-align: center; padding: 2rem; color: var(--text-muted);">Aún no se registran compras para tus actividades.</td>
              </tr>
            <% } else { %>
              <% financials.history.forEach(item => { %>
                <tr style="border-bottom: 1px solid var(--border); font-size: 0.95rem;">
                  <td style="padding: 0.75rem 1rem;"><strong><%= item.user_name %></strong></td>
                  <td style="padding: 0.75rem 1rem;"><%= item.tour_title %></td>
                  <td style="padding: 0.75rem 1rem;"><%= new Date(item.date).toLocaleDateString() %></td>
                  <td style="padding: 0.75rem 1rem; text-align: center;"><%= item.spots %></td>
                  <td style="padding: 0.75rem 1rem; text-align: right; color: var(--success); font-weight: bold;">$<%= item.amount.toFixed(2) %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</div>

    <!-- Modal para Editar Tour -->
<div id="edit-tour-modal" class="modal-overlay" style="display: none;">
  <div class="modal-content modal-content-lg" onclick="event.stopPropagation()">
    <h3 class="modal-header-margin">Editar Actividad</h3>
    
    <form id="edit-tour-form" action="" method="POST" enctype="multipart/form-data" onsubmit="return validateTourForm(this)">
      <div class="grid-2-col">
        <div class="form-group">
          <label for="edit-title">Título del Tour</label>
          <input type="text" id="edit-title" name="title" class="form-control" required>
        </div>
        
        <div class="form-group">
          <label for="edit-activity">Tipo de Actividad</label>
          <input type="text" id="edit-activity" name="activity" class="form-control" required>
        </div>
      </div>

      <div class="form-group form-group-margin">
        <label for="edit-description">Descripción</label>
        <textarea id="edit-description" name="description" rows="4" class="form-control" required></textarea>
      </div>

      <div class="grid-4-col">
        <div class="form-group">
          <label for="edit-continent">Continente</label>
          <select id="edit-continent" name="continent" class="form-control" required>
            <option value="América">América</option>
            <option value="Europa">Europa</option>
            <option value="Asia">Asia</option>
            <option value="África">África</option>
            <option value="Oceanía">Oceanía</option>
          </select>
        </div>
        
        <div class="form-group">
          <label for="edit-country">País</label>
          <input type="text" id="edit-country" name="country" class="form-control" required>
        </div>
        
        <div class="form-group">
          <label for="edit-city">Ciudad</label>
          <input type="text" id="edit-city" name="city" class="form-control" required>
        </div>

        <div class="form-group">
          <label for="edit-difficulty">Dificultad</label>
          <select id="edit-difficulty" name="difficulty" class="form-control" required>
            <option value="Fácil">Fácil</option>
            <option value="Medio">Medio</option>
            <option value="Difícil">Difícil</option>
          </select>
        </div>
      </div>

      <div class="grid-3-col">
        <div class="form-group">
          <label for="edit-duration">Duración</label>
          <input type="text" id="edit-duration" name="duration" class="form-control" required>
        </div>

        <div class="form-group">
          <label for="edit-price">Precio ($)</label>
          <input type="number" id="edit-price" name="price" class="form-control" min="1" step="0.01" required>
        </div>

        <div class="form-group">
          <label for="edit-spots_total">Cupos Totales</label>
          <input type="number" id="edit-spots_total" name="spots_total" class="form-control" min="1" required>
        </div>
      </div>

      <div class="form-group form-group-margin">
        <label for="edit-contact_info">Información de Contacto</label>
        <input type="text" id="edit-contact_info" name="contact_info" class="form-control" required>
      </div>

      <div class="grid-2-col" style="margin-top: 1rem; margin-bottom: 1.25rem;">
        <div class="form-group">
          <label for="edit-start_address">Dirección de inicio del tour</label>
          <input type="text" id="edit-start_address" name="start_address" class="form-control" required>
        </div>
        <div class="form-group">
          <label for="edit-coordinates">Coordenadas (Latitud, Longitud) - Opcional</label>
          <input type="text" id="edit-coordinates" name="coordinates" class="form-control">
        </div>
      </div>

      <div class="form-group form-group-margin">
        <label for="edit-activity_date">Fecha de la Actividad</label>
        <input type="date" id="edit-activity_date" name="activity_date" class="form-control" required min="<%= new Date().toISOString().split('T')[0] %>">
      </div>

      <div class="form-group form-group-margin">
        <label for="edit-images">Añadir más fotos (opcional)</label>
        <input type="file" id="edit-images" name="images" class="form-control" accept="image/*" multiple>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeEditTourModal()">Cancelar</button>
        <button type="submit" class="btn btn-success">Guardar Cambios</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openEditTourModal(tourStr) {
    const tour = JSON.parse(tourStr);
    const form = document.getElementById('edit-tour-form');
    form.action = '/tour/editar/' + tour._id;
    
    document.getElementById('edit-title').value = tour.title;
    document.getElementById('edit-activity').value = tour.activity;
    document.getElementById('edit-description').value = tour.description;
    document.getElementById('edit-continent').value = tour.continent;
    document.getElementById('edit-country').value = tour.country;
    document.getElementById('edit-city').value = tour.city;
    document.getElementById('edit-difficulty').value = tour.difficulty;
    document.getElementById('edit-duration').value = tour.duration;
    document.getElementById('edit-price').value = tour.price;
    document.getElementById('edit-spots_total').value = tour.spots_total;
    document.getElementById('edit-contact_info').value = tour.contact_info;
    document.getElementById('edit-start_address').value = tour.start_address || '';
    document.getElementById('edit-coordinates').value = tour.coordinates || '';
    document.getElementById('edit-activity_date').value = tour.activity_date ? tour.activity_date.split('T')[0] : '';

    document.getElementById('edit-tour-modal').style.display = 'flex';
  }

  function closeEditTourModal() {
    document.getElementById('edit-tour-modal').style.display = 'none';
  }

  function validateTourForm(form) {
    const addressInput = form.querySelector('[name="start_address"]');
    if (!addressInput) return true;
    
    const val = addressInput.value.trim();
    const isLink = /^(https?:\/\/)?(www\.)?(google\.com\/maps|maps\.google\.com|maps\.app\.goo\.gl|goo\.gl\/maps|http|www|\.gl)/i.test(val);
    
    if (isLink) {
      const isGoogleMaps = /^(https?:\/\/)?(www\.)?(google\.com\/maps|maps\.google\.com|maps\.app\.goo\.gl|goo\.gl\/maps)/i.test(val);
      if (!isGoogleMaps) {
        alert('Si ingresas un enlace en la dirección de inicio, debe ser un link válido de Google Maps.');
        addressInput.focus();
        return false;
      }
    }
    return true;
  }
</script>

<%- include('partials/footer') %>
