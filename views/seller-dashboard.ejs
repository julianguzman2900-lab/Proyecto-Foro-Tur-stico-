<%- include('partials/header') %>

<div class="dashboard-grid">
  <!-- Sidebar Menú -->
  <aside class="dashboard-sidebar">
    <div style="text-align: center; margin-bottom: 2rem;">
      <h3 style="font-weight: 800; font-size: 1.2rem;"><%= user.name %></h3>
      <p style="font-size: 0.8rem; color: var(--text-muted);">Proveedor verificado</p>
      
      <% if (user.status === 'pending') { %>
        <span class="badge badge-pending" style="margin-top: 0.5rem; display: inline-block;">Cuenta en revisión</span>
      <% } else if (user.status === 'approved') { %>
        <span class="badge badge-approved" style="margin-top: 0.5rem; display: inline-block;">Cuenta Aprobada</span>
      <% } else { %>
        <span class="badge badge-rejected" style="margin-top: 0.5rem; display: inline-block;">Cuenta Rechazada</span>
      <% } %>
    </div>
    
    <ul class="dashboard-menu">
      <li><a href="/vendedor/dashboard" class="dashboard-menu-link active">Mis Publicaciones</a></li>
      <li><a href="/quejas" class="dashboard-menu-link">Sugerencias & Quejas</a></li>
    </ul>
  </aside>

  <!-- Contenido Principal -->
  <div class="dashboard-content">
    
    <% if (user.status !== 'approved') { %>
      <div class="alert alert-warning" style="margin: 0;">
        ⚠️ <strong>Cuenta inactiva:</strong> Tu cuenta de proveedor está en espera de aprobación por parte de la administración de la plataforma. Podrás publicar nuevos tours una vez que seas aprobado.
      </div>
    <% } %>

    <!-- Tarjeta de Estadísticas Rápidas -->
    <div class="stat-grid">
      <div class="stat-card">
        <div class="stat-num"><%= stats.total %></div>
        <div class="stat-label">Publicaciones Totales</div>
      </div>
      <div class="stat-card">
        <div class="stat-num" style="color: var(--success);"><%= stats.active %></div>
        <div class="stat-label">Tours Activos</div>
      </div>
      <div class="stat-card">
        <div class="stat-num" style="color: var(--warning);"><%= stats.pending %></div>
        <div class="stat-label">En Revisión</div>
      </div>
    </div>

    <!-- Sección de Publicar Nuevo Tour -->
    <% if (user.status === 'approved') { %>
      <section class="detail-section" style="margin-bottom: 0;">
        <h3 style="font-weight: 800; font-size: 1.35rem; margin-bottom: 1.5rem;">Publicar Nueva Actividad Turística</h3>
        
        <form action="/tour" method="POST" enctype="multipart/form-data">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1rem;">
            <div class="form-group">
              <label for="title">Título del Tour</label>
              <input type="text" id="title" name="title" class="form-control" placeholder="Ej: Tour de snorkel en Arrecife de Coral" required>
            </div>
            
            <div class="form-group">
              <label for="activity">Tipo de Actividad</label>
              <input type="text" id="activity" name="activity" class="form-control" placeholder="Ej: Snorkel / Senderismo / Cultural" required>
            </div>
          </div>

          <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="description">Descripción Detallada (Solo letras, números y signos comunes)</label>
            <textarea id="description" name="description" rows="5" class="form-control" placeholder="Describe los itinerarios, qué incluye la actividad, políticas de seguridad, etc." required></textarea>
          </div>

          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
            <div class="form-group">
              <label for="continent">Continente</label>
              <select id="continent" name="continent" class="form-control" required>
                <option value="">Selecciona</option>
                <option value="América">América</option>
                <option value="Europa">Europa</option>
                <option value="Asia">Asia</option>
                <option value="África">África</option>
                <option value="Oceanía">Oceanía</option>
              </select>
            </div>
            
            <div class="form-group">
              <label for="country">País</label>
              <input type="text" id="country" name="country" class="form-control" placeholder="Ej: Costa Rica" required>
            </div>
            
            <div class="form-group">
              <label for="city">Ciudad</label>
              <input type="text" id="city" name="city" class="form-control" placeholder="Ej: Limón" required>
            </div>

            <div class="form-group">
              <label for="difficulty">Dificultad</label>
              <select id="difficulty" name="difficulty" class="form-control" required>
                <option value="Fácil">Fácil</option>
                <option value="Medio">Medio</option>
                <option value="Difícil">Difícil</option>
              </select>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
            <div class="form-group">
              <label for="duration">Duración</label>
              <input type="text" id="duration" name="duration" class="form-control" placeholder="Ej: 3 horas o 2 días" required>
            </div>

            <div class="form-group">
              <label for="price">Precio por Persona ($)</label>
              <input type="number" id="price" name="price" class="form-control" min="1" step="0.01" placeholder="Ej: 45" required>
            </div>

            <div class="form-group">
              <label for="spots_total">Cupos Totales</label>
              <input type="number" id="spots_total" name="spots_total" class="form-control" min="1" placeholder="Ej: 20" required>
            </div>

            <div class="form-group">
              <label for="images">Fotos de la Actividad</label>
              <input type="file" id="images" name="images" class="form-control" accept="image/*" multiple required>
            </div>
          </div>

          <div class="form-group" style="margin-bottom: 1.5rem;">
            <label for="contact_info">Información de Contacto directa (Teléfono, Whatsapp, etc.)</label>
            <input type="text" id="contact_info" name="contact_info" class="form-control" placeholder="Ej: WhatsApp +506 8888-8888 o reservas@ejemplo.com" required>
          </div>

          <button type="submit" class="btn btn-success" style="width: 100%; padding: 0.9rem;">Crear y Enviar Publicación</button>
        </form>
      </section>
    <% } %>

    <!-- Listado de Publicaciones Existentes -->
    <section class="table-container">
      <div style="padding: 1.5rem; border-bottom: 1px solid var(--border);">
        <h3 style="font-weight: 800; font-size: 1.2rem;">Estado de tus Publicaciones</h3>
      </div>
      
      <table>
        <thead>
          <tr>
            <th>Imagen</th>
            <th>Título del Tour</th>
            <th>Ubicación</th>
            <th>Precio</th>
            <th>Cupos</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% if (tours.length === 0) { %>
            <tr>
              <td colspan="7" style="text-align: center; color: var(--text-light); padding: 2rem;">No has subido ninguna publicación todavía.</td>
            </tr>
          <% } else { %>
            <% tours.forEach(tour => { %>
              <tr>
                <td>
                  <img src="<%= tour.images[0] || 'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=150' %>" alt="" style="width: 60px; height: 60px; object-fit: cover; border-radius: var(--radius-sm);">
                </td>
                <td>
                  <div style="font-weight: 700;"><%= tour.title %></div>
                  <div style="font-size: 0.8rem; color: var(--text-muted);"><%= tour.activity %></div>
                </td>
                <td><%= tour.city %>, <%= tour.country %></td>
                <td><strong>$<%= tour.price %></strong></td>
                <td><%= tour.spots_available %>/<%= tour.spots_total %></td>
                <td>
                  <% if (tour.status === 'approved') { %>
                    <span class="badge badge-approved">Publicado</span>
                  <% } else if (tour.status === 'pending') { %>
                    <span class="badge badge-pending">En revisión</span>
                  <% } else { %>
                    <span class="badge badge-rejected" style="cursor: help;" title="Haz clic para ver el motivo">Rechazado</span>
                  <% } %>
                </td>
                <td>
                  <div style="display: flex; gap: 0.5rem;">
                    <% if (tour.status === 'pending' || tour.status === 'rejected') { %>
                      <button class="btn btn-secondary" style="padding: 0.4rem 0.6rem; font-size: 0.8rem;" onclick="openEditTourModal('<%= JSON.stringify(tour).replace(/'/g, '&apos;') %>')">Editar</button>
                    <% } %>
                    <a href="/tour/eliminar/<%= tour._id %>" class="btn btn-danger" style="padding: 0.4rem 0.6rem; font-size: 0.8rem;" onclick="return confirm('¿Estás seguro de que deseas eliminar este tour?')">Eliminar</a>
                  </div>
                </td>
              </tr>
              <% if (tour.status === 'rejected' && tour.rejection_reason) { %>
                <tr style="background-color: var(--danger-light);">
                  <td colspan="7" style="padding: 0.75rem 1.5rem; font-size: 0.85rem; color: var(--danger); border-top: none;">
                    ❌ <strong>Motivo de rechazo de la administración:</strong> <%= tour.rejection_reason %>
                  </td>
                </tr>
              <% } %>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </section>
  </div>
</div>

<!-- Modal para Editar Tour -->
<div id="edit-tour-modal" class="modal-overlay" style="display: none;">
  <div class="modal-content" style="max-width: 700px; max-height: 90vh; overflow-y: auto;" onclick="event.stopPropagation()">
    <h3 style="margin-bottom: 1.5rem; font-weight: 800;">Editar Actividad</h3>
    
    <form id="edit-tour-form" action="" method="POST" enctype="multipart/form-data">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1rem;">
        <div class="form-group">
          <label for="edit-title">Título del Tour</label>
          <input type="text" id="edit-title" name="title" class="form-control" required>
        </div>
        
        <div class="form-group">
          <label for="edit-activity">Tipo de Actividad</label>
          <input type="text" id="edit-activity" name="activity" class="form-control" required>
        </div>
      </div>

      <div class="form-group" style="margin-bottom: 1.25rem;">
        <label for="edit-description">Descripción</label>
        <textarea id="edit-description" name="description" rows="4" class="form-control" required></textarea>
      </div>

      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.25rem;">
        <div class="form-group">
          <label for="edit-continent">Continente</label>
          <select id="edit-continent" name="continent" class="form-control" required>
            <option value="América">América</option>
            <option value="Europa">Europa</option>
            <option value="Asia">Asia</option>
            <option value="África">África</option>
            <option value="Oceanía">Oceanía</option>
          </select>
        </div>
        
        <div class="form-group">
          <label for="edit-country">País</label>
          <input type="text" id="edit-country" name="country" class="form-control" required>
        </div>
        
        <div class="form-group">
          <label for="edit-city">Ciudad</label>
          <input type="text" id="edit-city" name="city" class="form-control" required>
        </div>

        <div class="form-group">
          <label for="edit-difficulty">Dificultad</label>
          <select id="edit-difficulty" name="difficulty" class="form-control" required>
            <option value="Fácil">Fácil</option>
            <option value="Medio">Medio</option>
            <option value="Difícil">Difícil</option>
          </select>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.25rem;">
        <div class="form-group">
          <label for="edit-duration">Duración</label>
          <input type="text" id="edit-duration" name="duration" class="form-control" required>
        </div>

        <div class="form-group">
          <label for="edit-price">Precio ($)</label>
          <input type="number" id="edit-price" name="price" class="form-control" min="1" step="0.01" required>
        </div>

        <div class="form-group">
          <label for="edit-spots_total">Cupos Totales</label>
          <input type="number" id="edit-spots_total" name="spots_total" class="form-control" min="1" required>
        </div>
      </div>

      <div class="form-group" style="margin-bottom: 1.25rem;">
        <label for="edit-contact_info">Información de Contacto</label>
        <input type="text" id="edit-contact_info" name="contact_info" class="form-control" required>
      </div>

      <div class="form-group" style="margin-bottom: 1.5rem;">
        <label for="edit-images">Añadir más fotos (opcional)</label>
        <input type="file" id="edit-images" name="images" class="form-control" accept="image/*" multiple>
      </div>

      <div style="display: flex; justify-content: flex-end; gap: 1rem;">
        <button type="button" class="btn btn-secondary" onclick="closeEditTourModal()">Cancelar</button>
        <button type="submit" class="btn btn-success">Guardar Cambios</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openEditTourModal(tourStr) {
    const tour = JSON.parse(tourStr);
    const form = document.getElementById('edit-tour-form');
    form.action = '/tour/editar/' + tour._id;
    
    document.getElementById('edit-title').value = tour.title;
    document.getElementById('edit-activity').value = tour.activity;
    document.getElementById('edit-description').value = tour.description;
    document.getElementById('edit-continent').value = tour.continent;
    document.getElementById('edit-country').value = tour.country;
    document.getElementById('edit-city').value = tour.city;
    document.getElementById('edit-difficulty').value = tour.difficulty;
    document.getElementById('edit-duration').value = tour.duration;
    document.getElementById('edit-price').value = tour.price;
    document.getElementById('edit-spots_total').value = tour.spots_total;
    document.getElementById('edit-contact_info').value = tour.contact_info;

    document.getElementById('edit-tour-modal').style.display = 'flex';
  }

  function closeEditTourModal() {
    document.getElementById('edit-tour-modal').style.display = 'none';
  }
</script>

<%- include('partials/footer') %>
