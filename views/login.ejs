<%- include('partials/header') %>
<link rel="stylesheet" href="/css/login.css">

<div class="auth-container">
  <!-- Tarjeta de Login / Registro -->
  <div class="auth-card" id="auth-card">
    <div id="login-form-div">
      <h2 class="auth-title">¡Hola de nuevo!</h2>
      <p class="auth-subtitle">Inicia sesión para reservar actividades y comentar en el foro</p>
      
      <form action="/login" method="POST">
        <div class="form-group form-group-md">
          <label for="login-email">Correo Electrónico</label>
          <input type="email" id="login-email" name="email" class="form-control" placeholder="tu@correo.com" required>
        </div>
        
        <div class="form-group form-group-lg">
          <label for="login-password">Contraseña</label>
          <input type="password" id="login-password" name="password" class="form-control" placeholder="••••••••" required>
        </div>
        
        <button type="submit" class="btn btn-primary btn-full">Iniciar Sesión</button>
        
        <div class="oauth-divider">
          <span>o</span>
        </div>
        
        <a href="/auth/google" class="btn btn-google btn-full">
          <svg class="google-icon" viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
          </svg>
          Continuar con Google
        </a>
      </form>
      
      <div class="auth-footer">
        ¿No tienes cuenta? <a href="#" id="toggle-register">Regístrate gratis</a>
      </div>
    </div>

    <div id="register-form-div" style="display: none;">
      <h2 class="auth-title">Crear Cuenta</h2>
      <p class="auth-subtitle">Únete a GoWild para descubrir el mundo</p>
      
      <form action="/register" method="POST">
        <div class="form-group form-group-sm">
          <label for="reg-name">Nombre Completo</label>
          <input type="text" id="reg-name" name="name" class="form-control" placeholder="Juan Pérez" required>
        </div>
        
        <div class="form-group form-group-sm">
          <label for="reg-email">Correo Electrónico</label>
          <input type="email" id="reg-email" name="email" class="form-control" placeholder="tu@correo.com" required>
        </div>
        
        <div class="form-group form-group-sm">
          <label for="reg-password">Contraseña</label>
          <input type="password" id="reg-password" name="password" class="form-control" placeholder="Mínimo 6 caracteres" required>
        </div>

        <div class="form-group form-group-sm">
          <label for="reg-role">Tipo de Cuenta</label>
          <select id="reg-role" name="role" class="form-control" required>
            <option value="user">Viajero (Quiero reservar tours)</option>
            <option value="seller">Vendedor / Proveedor (Quiero publicar tours)</option>
          </select>
        </div>
        
        <!-- Campos adicionales para vendedor -->
        <div id="seller-fields" style="display: none; margin-top: 1rem; border-top: 1px dashed var(--border); padding-top: 1rem;">
          <div class="form-group form-group-sm">
            <label for="reg-country">País de origen</label>
            <input type="text" id="reg-country" name="country" class="form-control" placeholder="Ej: México">
          </div>
          <div class="form-group form-group-sm">
            <label for="reg-company">Nombre de la empresa</label>
            <input type="text" id="reg-company" name="company_name" class="form-control" placeholder="Ej: GoWild Adventures S.A.">
          </div>
        </div>
        
        <button type="submit" class="btn btn-success btn-full" style="margin-top: 1rem;">Crear Cuenta</button>
        
        <div class="oauth-divider">
          <span>o</span>
        </div>
        
        <a href="/auth/google" class="btn btn-google btn-full">
          <svg class="google-icon" viewBox="0 0 24 24" width="18" height="18" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
          </svg>
          Continuar con Google
        </a>
      </form>
      
      <div class="auth-footer">
        ¿Ya tienes cuenta? <a href="#" id="toggle-login">Inicia sesión</a>
      </div>
    </div>
  </div>
</div>

<script>
  const loginDiv = document.getElementById('login-form-div');
  const registerDiv = document.getElementById('register-form-div');
  const toggleRegister = document.getElementById('toggle-register');
  const toggleLogin = document.getElementById('toggle-login');
  
  const regRole = document.getElementById('reg-role');
  const sellerFields = document.getElementById('seller-fields');
  const regCountry = document.getElementById('reg-country');
  const regCompany = document.getElementById('reg-company');

  toggleRegister.addEventListener('click', (e) => {
    e.preventDefault();
    loginDiv.style.display = 'none';
    registerDiv.style.display = 'block';
  });

  toggleLogin.addEventListener('click', (e) => {
    e.preventDefault();
    registerDiv.style.display = 'none';
    loginDiv.style.display = 'block';
  });

  regRole.addEventListener('change', () => {
    if (regRole.value === 'seller') {
      sellerFields.style.display = 'block';
      regCountry.setAttribute('required', 'true');
      regCompany.setAttribute('required', 'true');
    } else {
      sellerFields.style.display = 'none';
      regCountry.removeAttribute('required');
      regCompany.removeAttribute('required');
      regCountry.value = '';
      regCompany.value = '';
    }
  });
</script>

<%- include('partials/footer') %>
