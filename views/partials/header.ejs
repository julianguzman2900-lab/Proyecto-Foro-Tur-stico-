<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GoWild - Foro Turístico & Reservas</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <nav class="navbar">
      <a href="/" class="logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--primary);"><path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        GoWild
      </a>
      <ul class="nav-links">
        <li><a href="/" id="nav-home">Inicio</a></li>
        
        <% if (user) { %>
          <li><a href="/quejas" id="nav-complaints">Quejas & Sugerencias</a></li>
          
          <% if (user.role === 'admin') { %>
            <li><a href="/admin/dashboard" id="nav-admin">Panel Admin</a></li>
          <% } else if (user.role === 'seller') { %>
            <li><a href="/vendedor/dashboard" id="nav-seller">Panel Vendedor</a></li>
          <% } else { %>
            <li><a href="/mis-reservas" id="nav-bookings">Mis Reservas</a></li>
          <% } %>
          
          <div class="user-info">
            <span class="user-tag <%= user.role %>"><%= user.role === 'admin' ? 'Administrador' : (user.role === 'seller' ? 'Proveedor' : 'Viajero') %></span>
            <span style="font-weight: 600;"><%= user.name %></span>
            <li><a href="/logout" class="btn btn-secondary" style="padding: 0.35rem 0.75rem; font-size: 0.85rem; color: var(--text-main);">Salir</a></li>
          </div>
        <% } else { %>
          <li><a href="/login" class="btn btn-primary" style="color: white; padding: 0.5rem 1rem;">Iniciar Sesión / Registro</a></li>
        <% } %>
      </ul>
    </nav>
  </header>

  <main class="main-content">
    <% if (error) { %>
      <div class="alert alert-danger" id="alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success" id="alert-success"><%= success %></div>
    <% } %>
