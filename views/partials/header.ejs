<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>La guía del viajero - Foro Turístico & Reservas</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/common.css">
</head>
<body>
  <header>
    <nav class="navbar">
      <a href="/" class="logo" style="font-family: 'DM Serif Display', serif; font-size: 1.6rem; letter-spacing: 0.5px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="logo-icon"><path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        La guía del viajero
      </a>

      <button class="hamburger-btn" aria-label="Abrir menú" aria-expanded="false" id="hamburger-menu">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12" class="line-mid"></line>
          <line x1="3" y1="6" x2="21" y2="6" class="line-top"></line>
          <line x1="3" y1="18" x2="21" y2="18" class="line-bottom"></line>
        </svg>
      </button>

      <ul class="nav-links" id="nav-menu">
        <li><a href="/" id="nav-home">Inicio</a></li>
        
        <% if (user) { %>
          <li><a href="/chat" id="nav-chat">Chat en Vivo</a></li>
          <li><a href="/quejas" id="nav-complaints">Quejas & Sugerencias</a></li>
          
          <% if (user.role === 'admin') { %>
            <li><a href="/admin/dashboard" id="nav-admin">Panel Admin</a></li>
          <% } else if (user.role === 'seller') { %>
            <li><a href="/vendedor/dashboard" id="nav-seller">Panel Vendedor</a></li>
          <% } else { %>
            <li><a href="/mis-reservas" id="nav-bookings">Mis Reservas</a></li>
          <% } %>
          
          <div class="user-info">
            <span class="user-tag <%= user.role %>"><%= user.role === 'admin' ? 'Administrador' : (user.role === 'seller' ? 'Proveedor' : 'Viajero') %></span>
            <span class="user-name"><%= user.name %></span>
            <li><a href="/logout" class="btn btn-secondary btn-logout">Salir</a></li>
          </div>
        <% } else { %>
          <li><a href="/login" class="btn btn-primary btn-login">Iniciar Sesión / Registro</a></li>
        <% } %>
      </ul>
    </nav>
  </header>

  <main class="main-content">
    <% if (error) { %>
      <div class="alert alert-danger" id="alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success" id="alert-success"><%= success %></div>
    <% } %>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const alerts = document.querySelectorAll('.alert');
        alerts.forEach(alert => {
          setTimeout(() => {
            alert.style.opacity = '0';
            alert.style.transition = 'opacity 0.5s ease-out';
            setTimeout(() => {
              alert.style.display = 'none';
            }, 500);
          }, 4000); // 4 segundos de visualización
        });

        // Menú Hamburguesa
        const hamburgerBtn = document.getElementById('hamburger-menu');
        const navMenu = document.getElementById('nav-menu');
        
        if (hamburgerBtn && navMenu) {
          hamburgerBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            const isExpanded = hamburgerBtn.getAttribute('aria-expanded') === 'true';
            hamburgerBtn.setAttribute('aria-expanded', !isExpanded);
            navMenu.classList.toggle('show-menu');
            hamburgerBtn.classList.toggle('open');
          });

          // Cerrar al hacer click fuera
          document.addEventListener('click', (e) => {
            if (navMenu.classList.contains('show-menu') && !navMenu.contains(e.target) && !hamburgerBtn.contains(e.target)) {
              navMenu.classList.remove('show-menu');
              hamburgerBtn.classList.remove('open');
              hamburgerBtn.setAttribute('aria-expanded', 'false');
            }
          });

          // Cerrar al seleccionar una opción (enlaces)
          const navItems = navMenu.querySelectorAll('a');
          navItems.forEach(item => {
            item.addEventListener('click', () => {
              navMenu.classList.remove('show-menu');
              hamburgerBtn.classList.remove('open');
              hamburgerBtn.setAttribute('aria-expanded', 'false');
            });
          });
        }
      });
    </script>
